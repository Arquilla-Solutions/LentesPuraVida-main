---
import { Icon } from "astro-icon/components";
import logo from "@/assets/logo.png";
import { WHATSAPP_LINK } from "@/lib/contact";

// Copyright year — Astro renders this at build time, so it stays fresh on every deploy.
const year = new Date().getFullYear();
---

<footer class="site-footer" aria-label="Pie de página">
  <div class="site-footer-inner">
    <div class="site-footer-brand">
      <a href="/" class="site-footer-logo" aria-label="Lentes Pura Vida — inicio">
        <img src={logo.src} alt="" />
        <span>Lentes <em>Pura Vida</em></span>
      </a>
      <p class="site-footer-tag">
        Lentes recetados premium fabricados en Estados Unidos por optómetras certificados.
        Cotización transparente y envío a toda Costa Rica.
      </p>
      <div class="site-footer-cr">
        <span class="site-footer-cr-flag" aria-hidden="true">🇨🇷</span>
        <span>Hecho con cariño para Costa Rica</span>
      </div>
    </div>

    <div class="site-footer-col">
      <h4>Catálogo</h4>
      <ul>
        <li><a href="/#catalogo">Hombres</a></li>
        <li><a href="/#catalogo">Mujeres</a></li>
        <li><a href="/#catalogo">Niños</a></li>
        <li><a href="/#catalogo">Unisex</a></li>
        <li><a href="/sobre-nosotros">Sobre nosotros</a></li>
        <li><a href="/#top">Cómo funciona</a></li>
      </ul>
    </div>

    <div class="site-footer-col">
      <h4>Atención al cliente</h4>
      <ul>
        <li>
          <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer">
            <Icon name="lucide:message-circle" size={14} aria-hidden="true" /> WhatsApp
          </a>
        </li>
        <li>
          <Icon name="lucide:clock" size={14} aria-hidden="true" />
          Respondemos en minutos
        </li>
        <li>
          <Icon name="lucide:globe" size={14} aria-hidden="true" />
          Tienda 100% online
        </li>
        <li>
          <Icon name="lucide:map-pin" size={14} aria-hidden="true" />
          Envío a todo CR
        </li>
      </ul>
    </div>

    <div class="site-footer-col">
      <h4>Pago seguro</h4>
      <div class="site-footer-pay">
        <span>SINPE Móvil</span>
        <span>Transferencia</span>
        <span>Tarjeta</span>
      </div>
      <h4 class="site-footer-h4--mt">Garantías</h4>
      <ul class="site-footer-trust">
        <li>
          <Icon name="lucide:award" size={14} aria-hidden="true" />
          Optómetras certificados
        </li>
        <li>
          <Icon name="lucide:truck" size={14} aria-hidden="true" />
          Envío rastreable
        </li>
        <li>
          <Icon name="lucide:shield-check" size={14} aria-hidden="true" />
          Garantía de fábrica
        </li>
      </ul>
    </div>
  </div>

  <div class="site-footer-bottom">
    <span>© {year} Lentes Pura Vida</span>
    <span aria-hidden="true">·</span>
    <span>Catálogo oficial · Costa Rica</span>
    <span aria-hidden="true">·</span>
    <span>Precios y disponibilidad sujetos a cambio</span>
  </div>
</footer>
